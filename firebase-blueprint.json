{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique identifier."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's avatar URL."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role."
        },
        "bio": {
          "type": "string",
          "description": "The user's bio."
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "The user's skills."
        },
        "interests": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "The user's interests."
        },
        "notifications": {
          "type": "object",
          "properties": {
            "emailAlerts": { "type": "boolean" },
            "pushNotifications": { "type": "boolean" },
            "weeklyDigest": { "type": "boolean" }
          },
          "description": "The user's notification preferences."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created."
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles."
    }
  }
}
